# Telegram Bot Token (obtained from @BotFather)
TELEGRAM_BOT_TOKEN=123456789:AA-your-bot-token-from-BotFather

# Public WebApp URL (should match your ngrok static domain address)
WEBAPP_URL=https://your-ngrok-subdomain.ngrok-free.app

# Comma-separated list of Telegram User IDs allowed to access the admin panel
ADMIN_TELEGRAM_IDS=123456789

# Admin panel passcode (sent as X-Admin-Passcode header)
ADMIN_PASSCODE=change-me

# OpenAI API key for the AI support chat (function-assistant mode)
OPENAI_API_KEY=sk-your-openai-api-key

# Ngrok Authtoken and static domain (obtained from dashboard.ngrok.com)
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
NGROK_DOMAIN=your-static-domain.ngrok-free.dev
